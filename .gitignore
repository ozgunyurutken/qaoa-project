# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.installed.cfg

# Virtual environments
venv/
env/
.venv/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# Results (data + figures) are tracked in this repository as submission artefacts.
# Keep .gitkeep sentinels for empty directories.
!results/data/.gitkeep
!results/figures/.gitkeep

# LaTeX auxiliary files (PDF itself is committed)
presentation/*.aux
presentation/*.log
presentation/*.nav
presentation/*.out
presentation/*.snm
presentation/*.toc
presentation/*.vrb

# Env
.env
